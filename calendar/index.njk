---
title: Calendar
layout: base.njk
---
<div class="container">
    <h1>Calendar</h1>

    <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js"></script>

    <!-- Event detail popup -->
    <div id="cal-modal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999;">
        <div style="background:#fff; max-width:480px; margin:80px auto; padding:30px; border-radius:8px; position:relative;">
            <button onclick="document.getElementById('cal-modal').style.display='none'"
                style="position:absolute; top:10px; right:15px; background:none; border:none; font-size:22px; cursor:pointer;">&times;</button>
            <h3 id="modal-title" style="margin-top:0; color:#1F3864;"></h3>
            <p id="modal-datetime" style="color:#555;"></p>
            <p id="modal-location" style="color:#555;"></p>
            <p id="modal-description" style="color:#333;"></p>
        </div>
    </div>

    <div id="my-calendar"></div>

    <script>
    window.addEventListener('load', function () {
        fetch('/api/calendar')
            .then(function (res) { return res.json(); })
            .then(function (events) {
                var calendarEl = document.getElementById('my-calendar');
                var calendar = new FullCalendar.Calendar(calendarEl, {
                    initialView: 'dayGridMonth',
                    headerToolbar: {
                        left:   'prev,next today',
                        center: 'title',
                        right:  'dayGridMonth,timeGridWeek,listMonth,multiMonthYear'
                    },
                    views: {
                        multiMonthYear: {
                            type:               'multiMonth',
                            duration:           { years: 1 },
                            multiMonthMaxColumns: 3
                        },
                        listMonth: { buttonText: 'list' }
                    },
                    events: events,
                    height: 'auto',
                    eventClick: function (info) {
                        var event = info.event;
                        var props = event.extendedProps;

                        document.getElementById('modal-title').innerText = event.title;

                        var start   = event.start;
                        var end     = event.end;
                        var dateStr = start ? start.toLocaleDateString('en-GB', {
                            weekday: 'long', year: 'numeric',
                            month: 'long', day: 'numeric'
                        }) : '';
                        var timeStr = '';
                        if (start && start.getHours() !== 0) {
                            timeStr = ' — ' + start.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
                            if (end) timeStr += ' to ' + end.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
                        }
                        document.getElementById('modal-datetime').innerText = dateStr + timeStr;

                        var locEl = document.getElementById('modal-location');
                        if (props.location) {
                            locEl.innerText = '📍 ' + props.location;
                            locEl.style.display = 'block';
                        } else {
                            locEl.style.display = 'none';
                        }

                        var descEl = document.getElementById('modal-description');
                        if (props.description) {
                            descEl.innerText = props.description;
                            descEl.style.display = 'block';
                        } else {
                            descEl.style.display = 'none';
                        }

                        document.getElementById('cal-modal').style.display = 'block';
                    }
                });
                calendar.render();
            })
            .catch(function (err) {
                document.getElementById('my-calendar').innerText = 'Calendar unavailable. Please try again later.';
            });
    });
    </script>
</div>