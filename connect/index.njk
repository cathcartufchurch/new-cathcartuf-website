<script>
    document.getElementById('prayerForm').addEventListener('submit', async function (e) {
        e.preventDefault();

        const statusDiv = document.getElementById('prayerStatus');
        statusDiv.textContent = 'Submitting...';
        statusDiv.style.color = 'black';

        const formData = {
            name: document.getElementById('prayerName').value,
            email: document.getElementById('prayerEmail').value || null,
            phone: document.getElementById('prayerPhone').value || null,
            prayerRequest: document.getElementById('prayerMessage').value,
            isPrivate: document.getElementById('prayerPrivate').checked,
            wantZoom: document.getElementById('prayerZoom').checked
        };

        try {
            const response = await fetch('/api/prayer', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(formData)
            });

            let data;
            try {
                data = await response.json();
            } catch (e) {
                statusDiv.textContent = 'Server error: ' + response.status;
                statusDiv.style.color = 'red';
                return;
            }

            if (response.ok) {
                statusDiv.textContent = data.message;
                statusDiv.style.color = 'green';
                document.getElementById('prayerForm').reset();
            } else {
                statusDiv.textContent = data.error || 'Failed to submit. Please try again.';
                statusDiv.style.color = 'red';
            }
        } catch (error) {
            statusDiv.textContent = 'Error: ' + error.message;
            statusDiv.style.color = 'red';
            console.error('Error:', error);
        }
    });
</script>
